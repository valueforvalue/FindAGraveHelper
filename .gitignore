# Local tooling
.antigravitycli/

# Python bytecode
__pycache__/
*.pyc

# Research artifacts that are large and reproducible from public sources.
# See docs/research/broadened-set/README.md for the URLs to re-download.
docs/research/broadened-set/rosters/

# Local exports of the user's dixiedata database. May contain
# personal/family-tree data the user does not want to publish.
docs/research/local-data/local_soldiers_with_fag.csv
docs/research/local-data/local_fag_records.csv

# Digital Prairie pension records — large and reproducible by
# re-running scripts/scrape_digitalprairie.py. The unified canonical
# list (unified.{json,csv}) IS committed; the per-collection files
# and the scrape log are gitignored.
docs/research/digitalprairie/pensions.csv
docs/research/digitalprairie/pensions.json
docs/research/digitalprairie/pensioncard.csv
docs/research/digitalprairie/pensioncard.json
docs/research/digitalprairie/scrape.log

# CGR (Confederate Graves Registry) bulk scrapes — research data
# is COMMITTED to the repo for future reference and cross-state
# comparison. See docs/research/cgr/README.md. The scraper is
# idempotent and resume-safe so it can be re-run; the committed
# copy is the snapshot at time of the original scrape.
#
# If a future scrape supersedes the committed data, replace
# the files in place rather than ignore-then-regenerate.

# Run outputs (state.jsonl, outliers.jsonl, run.log, reports).
# Resume-safe by design (file is flushed per-pensioner + ResumeTracker).
# Keep outputs local; final report is regenerated from this data.
data/results/

# Probe artifacts (one-off investigation scripts + captured HTML/JSON).
# Prefix scripts with underscore (_probe_*.py) and output goes under
# data/probe/. Kept local; the commit message cites key findings inline.
data/probe/
scripts/_probe_*.py

# One-off HTML preview renders from data/preview_view.html experiments.
data/preview_view.html